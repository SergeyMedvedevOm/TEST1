&НаСервере
Процедура ЗаполнитьПрофильПоПользователюНаСервере(ПрофильДляЗаполнения)
	
	Если НастройкиАвторизации.ИспользуетсяАутентификацияОС Тогда 
		Аутентификация = Новый Структура("Аутентификация", КоннекторHTTP.НоваяАутентификацияОС());		
	Иначе                                                    
		Аутентификация = Новый Структура("Аутентификация", Новый Структура("Пользователь, Пароль", НастройкиАвторизации.ИмяПользователя, НастройкиАвторизации.Пароль));	
	КонецЕсли;
	
	Для Каждого Стр Из Получатели Цикл
		
		
		ПутьНаВебСервере = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Стр.ИБ, "ПутьНаВебСервере");	
		
		Попытка 
			Ответ = Интеграция.ОбратитьсяКВебСервису(ПутьНаВебСервере, "GET", "DataProcessings/UserAccessGroups", Аутентификация, Новый Структура("ИмяПользователя", ПрофильДляЗаполнения));
		Исключение
			ОбщегоНазначения.СообщитьПользователю("Ошибка при получении сведений о пользователе " + ПутьНаВебСервере + Символы.ПС + ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())); 
		КонецПопытки;  
		
		Если Ответ = Неопределено Тогда 
			Продолжить;
		КонецЕсли;
		
		Если ТипЗнч(Ответ) = Тип("Структура") Тогда
			Если Ответ.Свойство("error") И Ответ.error Тогда    
				ТекстОшибки = "Ошибка при получении сведений о пользователе " + ПутьНаВебСервере + Символы.ПС + Ответ.message;
				ОбщегоНазначения.СообщитьПользователю(ТекстОшибки);				
			КонецЕсли;				
		КонецЕсли; 
		
		Если Не Ответ.Количество() Тогда 
			Продолжить;
		КонецЕсли;
		
		Стр.Профили.Очистить();
		Для каждого Профиль Из Ответ Цикл
			Стр.Профили.Добавить(Профиль,,Истина);	
		КонецЦикла;		

	КонецЦикла;
		
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТЧДоступы()
	ТекущийОбъект = РеквизитФормыВЗначение("Объект");
	ТекущийОбъект.Доступы.Очистить();
	ТекущийОбъект.ДоступыГруппы.Очистить();
	НовоеОписание = "Базы: ";
	Шаблон = "%1 (%2)";
	МассивОписаний = Новый Массив; 
	Для Каждого СтрокаДоступа Из Получатели Цикл
		КоличествоРолей = 0;
		Для Каждого Эл Из СтрокаДоступа.Профили Цикл
			НоваяСтрока = ТекущийОбъект.Доступы.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДоступа);
			НоваяСтрока.Профиль = Эл.Значение;
			КоличествоРолей = КоличествоРолей + 1;
		КонецЦикла;
		МассивОписаний.Добавить(СтрШаблон(Шаблон, СтрокаДоступа.ИБ, КоличествоРолей));
		Если СтрокаДоступа.Группы.Количество() = 0 = Ложь Тогда
			Для Каждого Эл Из СтрокаДоступа.Группы Цикл
				НоваяСтрока = ТекущийОбъект.ДоступыГруппы.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДоступа);
				НоваяСтрока.Группа = Эл.Значение;
			КонецЦикла;			
		КонецЕсли;
	КонецЦикла;
	НовоеОписание = НовоеОписание + СтрСоединить(МассивОписаний, ", ");
	ТекущийОбъект.Описание = НовоеОписание;
	ЗначениеВРеквизитФормы(ТекущийОбъект, "Объект");
КонецПроцедуры


Функция GETLICENSESGet(Запрос) Экспорт
	
	Попытка
		
		ДатаОкончания = ТекущаяДата();
		ДатаНачала    = ДатаОкончания - 7 * 24 * 60 * 60;
		
		МенеджерВТ = Новый МенеджерВременныхТаблиц;
		
		Запрос1 = Новый Запрос;
		Запрос1.МенеджерВременныхТаблиц = МенеджерВТ;
		Запрос1.Текст = "
		|ВЫБРАТЬ
		|	СерверПриложений.Наименование КАК ИмяСервера,
		|	СерверПриложений.Ссылка       КАК Сервер
		|ПОМЕСТИТЬ ВТСерверы
		|ИЗ Справочник.СерверПриложений КАК СерверПриложений";
		Запрос1.Выполнить();
		
		Запрос2 = Новый Запрос;
		Запрос2.МенеджерВременныхТаблиц = МенеджерВТ;
		Запрос2.Текст = "
		|ВЫБРАТЬ
		|	Статистика.Период КАК Дата,
		|	ВТСерверы.Сервер  КАК Сервер,
		|	СУММА(Статистика.ИспользуемыхЛицензий) КАК ВсегоИспользовано
		|ПОМЕСТИТЬ ВТСтатистика
		|ИЗ РегистрСведений.Статистика КАК Статистика
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВТСерверы КАК ВТСерверы
		|		ПО (ВТСерверы.ИмяСервера = Статистика.Сервер)
		|ГДЕ
		|	Статистика.ВремяНачалаРаботы МЕЖДУ &ДатаНачала И &ДатаОкончания
		|СГРУППИРОВАТЬ ПО
		|	ВТСерверы.Сервер, Статистика.Период";
		Запрос2.УстановитьПараметр("ДатаНачала",    ДатаНачала);
		Запрос2.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
		Запрос2.Выполнить();
		
		Запрос3 = Новый Запрос;
		Запрос3.МенеджерВременныхТаблиц = МенеджерВТ;
		Запрос3.Текст = "
		|ВЫБРАТЬ
		|	КомплектыПоставки.СерверПриложений КАК СерверЛицензирования,
		|	СУММА(КомплектыПоставки.КоличествоКлиентскихСеансов) КАК ВсегоДоступноЛицензий
		|ПОМЕСТИТЬ ВТЛицензии
		|ИЗ Справочник.КомплектыПоставки КАК КомплектыПоставки
		|ГДЕ
		|	КомплектыПоставки.ТипЛицензии = ЗНАЧЕНИЕ(Перечисление.ТипыЛицензий.Клиентская)
		|СГРУППИРОВАТЬ ПО
		|	КомплектыПоставки.СерверПриложений";
		Запрос3.Выполнить();
		
		// Финальный — группируем по СЕРВЕРУ ЛИЦЕНЗИРОВАНИЯ и дню
		ЗапросФинал = Новый Запрос;
		ЗапросФинал.МенеджерВременныхТаблиц = МенеджерВТ;
		ЗапросФинал.Текст = "
		|ВЫБРАТЬ
		|	НАЧАЛОПЕРИОДА(ВТСтатистика.Дата, ДЕНЬ)         КАК Дата,
		|	СерверПриложений.СерверЛицензирования           КАК СерверЛицензирования,
		|	ВТСтатистика.Сервер                              КАК Сервер,
		|	СерверПриложений.Наименование                   КАК ИмяСервера,
		|	МАКСИМУМ(ВТСтатистика.ВсегоИспользовано)        КАК МаксИспользовано,
		|	ЕСТЬNULL(ВТЛицензии.ВсегоДоступноЛицензий, 0)  КАК ВсегоДоступно
		|ИЗ ВТСтатистика КАК ВТСтатистика
		|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СерверПриложений КАК СерверПриложений
		|		ПО (СерверПриложений.Ссылка = ВТСтатистика.Сервер)
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВТЛицензии КАК ВТЛицензии
		|		ПО (ВТЛицензии.СерверЛицензирования = СерверПриложений.СерверЛицензирования)
		|СГРУППИРОВАТЬ ПО
		|	НАЧАЛОПЕРИОДА(ВТСтатистика.Дата, ДЕНЬ),
		|	СерверПриложений.СерверЛицензирования,
		|	ВТСтатистика.Сервер,
		|	СерверПриложений.Наименование,
		|	ВТЛицензии.ВсегоДоступноЛицензий
		|УПОРЯДОЧИТЬ ПО
		|	СерверПриложений.СерверЛицензирования,
		|	Дата,
		|	ВТСтатистика.Сервер";
		
		Выборка = ЗапросФинал.Выполнить().Выбрать();
		
		// ── Структуры для графика и таблицы ──────────────────────
		// Для графика: по каждому серверу лицензирования
		// ключ = ИмяСервЛиц, значение = соответствие Дата->МаксИсп (суммируем все серверы приложений)
		ДанныеГрафика    = Новый Соответствие; // СервЛиц -> (Дата -> МаксИсп)
		ДоступноПоСервЛиц = Новый Соответствие; // СервЛиц -> ВсегоДоступно
		УникальныеДаты   = Новый Соответствие; // Дата -> Истина (для оси X)
		МассивТаблицы    = Новый Массив;
		
		Пока Выборка.Следующий() Цикл
			ИмяСервЛиц = Строка(Выборка.СерверЛицензирования);
			ДатаСтр    = Формат(Выборка.Дата, "ДФ=дд.ММ");
			МаксИсп    = Выборка.МаксИспользовано;
			ВсегоДост  = Выборка.ВсегоДоступно;
			
			// Уникальные даты для оси X
			УникальныеДаты.Вставить(ДатаСтр, Истина);
			
			// Данные графика — суммируем макс по всем серверам приложений за день
			Если ДанныеГрафика[ИмяСервЛиц] = Неопределено Тогда
				ДанныеГрафика.Вставить(ИмяСервЛиц, Новый Соответствие);
			КонецЕсли;
			ТекЗнач = ДанныеГрафика[ИмяСервЛиц][ДатаСтр];
			Если ТекЗнач = Неопределено Тогда
				ДанныеГрафика[ИмяСервЛиц].Вставить(ДатаСтр, МаксИсп);
			Иначе
				ДанныеГрафика[ИмяСервЛиц].Вставить(ДатаСтр, ТекЗнач + МаксИсп);
			КонецЕсли;
			
			// Доступно по серверу лицензирования
			ДоступноПоСервЛиц.Вставить(ИмяСервЛиц, Формат(ВсегоДост, "ЧГ=0; ЧН=0"));
			
			// Строка таблицы
			СтрТаб = Новый Структура("Дата,ИмяСервера,ИмяСервЛиц,МаксИсп,ВсегоДост,Доступно");
			СтрТаб.Дата       = Формат(Выборка.Дата, "ДФ=дд.ММ.гггг");
			СтрТаб.ИмяСервера = Строка(Выборка.ИмяСервера);
			СтрТаб.ИмяСервЛиц = ИмяСервЛиц;
			СтрТаб.МаксИсп    = Формат(МаксИсп,  "ЧГ=0; ЧН=0");
			СтрТаб.ВсегоДост  = Формат(ВсегоДост, "ЧГ=0; ЧН=0");
			СтрТаб.Доступно   = Формат(ВсегоДост - МаксИсп, "ЧГ=0; ЧН=0");
			МассивТаблицы.Добавить(СтрТаб);
		КонецЦикла;
		
		// ── Формируем labels (ось X) — отсортированные даты ──────
		МассивДат = Новый Массив;
		Для Каждого КД Из УникальныеДаты Цикл
			МассивДат.Добавить(КД.Ключ);
		КонецЦикла;
		// Сортируем простым пузырьком (дат мало — 7 штук)
		Для й = 0 По МассивДат.Количество() - 2 Цикл
			Для к = 0 По МассивДат.Количество() - й - 2 Цикл
				Если МассивДат[к] > МассивДат[к+1] Тогда
					Врем = МассивДат[к];
					МассивДат[к]   = МассивДат[к+1];
					МассивДат[к+1] = Врем;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
		
		// labels JS
		ЛейблыJS = "";
		Для Каждого Д Из МассивДат Цикл
			Если НЕ ПустаяСтрока(ЛейблыJS) Тогда ЛейблыJS = ЛейблыJS + ","; КонецЕсли;
			ЛейблыJS = ЛейблыJS + """" + Д + """";
		КонецЦикла;
		
		// ── Datasets: одна линия = один сервер лицензирования ────
		ЦветаПалитра = Новый Массив;
		ЦветаПалитра.Добавить("54,114,196");   // синий
		ЦветаПалитра.Добавить("231,76,60");    // красный
		ЦветаПалитра.Добавить("39,174,96");    // зелёный
		ЦветаПалитра.Добавить("243,156,18");   // жёлтый
		ЦветаПалитра.Добавить("142,68,173");   // фиолетовый
		ЦветаПалитра.Добавить("22,160,133");   // бирюзовый
		
		ДатасетыJS  = "";
		ИндексЦвета = 0;
		
		Для Каждого КлючЗнач Из ДанныеГрафика Цикл
			ИмяСервЛиц = КлючЗнач.Ключ;
			ДатыПоСерв = КлючЗнач.Значение;
			Цвет        = ЦветаПалитра[ИндексЦвета % ЦветаПалитра.Количество()];
			ДоступноЧисло = ДоступноПоСервЛиц[ИмяСервЛиц];
			
			// Значения строго по порядку дат
			ЗначенияJS = "";
			Для Каждого Д Из МассивДат Цикл
				Если НЕ ПустаяСтрока(ЗначенияJS) Тогда ЗначенияJS = ЗначенияJS + ","; КонецЕсли;
				ЗначДня = ДатыПоСерв[Д];
				ЗначенияJS = ЗначенияJS + ?(ЗначДня = Неопределено, "null", Формат(ЗначДня, "ЧГ=0; ЧН=0"));
			КонецЦикла;
			
			Если НЕ ПустаяСтрока(ДатасетыJS) Тогда ДатасетыJS = ДатасетыJS + ","; КонецЕсли;
			// Линия — использовано
			ДатасетыJS = ДатасетыJS + "
			|{
			|  label: 'Использовано: " + ИмяСервЛиц + "',
			|  data: [" + ЗначенияJS + "],
			|  borderColor: 'rgba(" + Цвет + ",1)',
			|  backgroundColor: 'rgba(" + Цвет + ",0.08)',
			|  borderWidth: 2, pointRadius: 5, tension: 0.3, fill: false
			|},
			|{
			|  label: 'Доступно: " + ИмяСервЛиц + "',
			|  data: Array(" + Формат(МассивДат.Количество(), "ЧГ=0") + ").fill(" + ДоступноЧисло + "),
			|  borderColor: 'rgba(" + Цвет + ",0.35)',
			|  borderDash: [6,4],
			|  borderWidth: 1.5, pointRadius: 0, tension: 0, fill: false
			|}";
			
			ИндексЦвета = ИндексЦвета + 1;
		КонецЦикла;
		
		// ── Карточки серверов лицензирования ─────────────────────
		КарточкиHTML = "";
		Для Каждого КлючЗнач Из ДоступноПоСервЛиц Цикл
			// Последнее использовано по этому серверу
			ПоследняяДата = ?(МассивДат.Количество() > 0, МассивДат[МассивДат.Количество()-1], "");
			ПослИсп = 0;
			Если НЕ ПустаяСтрока(ПоследняяДата) И ДанныеГрафика[КлючЗнач.Ключ] <> Неопределено Тогда
				ЗначПосл = ДанныеГрафика[КлючЗнач.Ключ][ПоследняяДата];
				Если ЗначПосл <> Неопределено Тогда ПослИсп = ЗначПосл; КонецЕсли;
			КонецЕсли;
			Доступно  = Число(КлючЗнач.Значение) - ПослИсп;
			Перц      = ?(Число(КлючЗнач.Значение) > 0,
			Цел(ПослИсп / Число(КлючЗнач.Значение) * 100), 0);
			ЦветПерц  = ?(Перц >= 90, "#e74c3c", ?(Перц >= 70, "#f39c12", "#27ae60"));
			КарточкиHTML = КарточкиHTML + "
			|<div class='lic-card'>
			|  <div class='lic-name'> " + КлючЗнач.Ключ + "</div>
			|  <div class='lic-row'>
			|    <div class='lic-block'>
			|      <div class='lic-val blue'>" + КлючЗнач.Значение + "</div>
			|      <div class='lic-lbl'>Всего</div>
			|    </div>
			|    <div class='lic-block'>
			|      <div class='lic-val' style='color:" + ЦветПерц + "'>" + Формат(ПослИсп, "ЧГ=0; ЧН=0") + "</div>
			|      <div class='lic-lbl'>Использовано</div>
			|    </div>
			|    <div class='lic-block'>
			|      <div class='lic-val green'>" + Формат(Доступно, "ЧГ=0; ЧН=0") + "</div>
			|      <div class='lic-lbl'>Свободно</div>
			|    </div>
			|    <div class='lic-block'>
			|      <div class='lic-val' style='color:" + ЦветПерц + "'>" + Формат(Перц, "ЧГ=0") + "%</div>
			|      <div class='lic-lbl'>Загрузка</div>
			|    </div>
			|  </div>
			|  <div class='progress-wrap'>
			|    <div class='progress-bar' style='width:" + Формат(Перц, "ЧГ=0") + "%;background:" + ЦветПерц + "'></div>
			|  </div>
			|</div>";
		КонецЦикла;
		
		// ── Строки таблицы ────────────────────────────────────────
		ТекущийСервЛиц = Неопределено;
		ТекущийСервер  = Неопределено;
		НомерГруппы    = 0;
		НомерСтроки    = 0;
		ТелоТаблицы    = "";
		ИдГруппы       = "";
		
		Для Каждого СтрТаб Из МассивТаблицы Цикл
			
			Если СтрТаб.ИмяСервЛиц <> ТекущийСервЛиц Тогда
				ТекущийСервЛиц = СтрТаб.ИмяСервЛиц;
				ТекущийСервер  = Неопределено;
				НомерГруппы    = НомерГруппы + 1;
				НомерСтроки    = 0;
				ИдГруппы       = "g" + Формат(НомерГруппы, "ЧГ=0");
				ТелоТаблицы    = ТелоТаблицы + "
				|<tr class='grp-lic' onclick=""toggleGroup('" + ИдГруппы + "')"">
				|  <td colspan='6'>
				|    <span id='icon_" + ИдГруппы + "'>▼</span>
				|    &nbsp; " + ТекущийСервЛиц + "
				|    <span class='badge-avail'>Всего: " + СтрТаб.ВсегоДост + "</span>
				|  </td>
				|</tr>";
			КонецЕсли;
			
			Если СтрТаб.ИмяСервера <> ТекущийСервер Тогда
				ТекущийСервер = СтрТаб.ИмяСервера;
				НомерСтроки   = 0;
				ТелоТаблицы   = ТелоТаблицы + "
				|<tr class='grp-srv kontour-group " + ИдГруппы + "'>
				|  <td colspan='6'> " + ТекущийСервер + "</td>
				|</tr>";
			КонецЕсли;
			
			НомерСтроки = НомерСтроки + 1;
			КлассСтр    = ?(НомерСтроки % 2 = 0, "even", "odd");
			Перц = 0;
			Если Число(СтрТаб.ВсегоДост) > 0 Тогда
				Перц = Цел(Число(СтрТаб.МаксИсп) / Число(СтрТаб.ВсегоДост) * 100);
			КонецЕсли;
			ЦветПерц = ?(Перц >= 90, "#e74c3c", ?(Перц >= 70, "#f39c12", "#27ae60"));
			
			ТелоТаблицы = ТелоТаблицы + "
			|<tr class='" + КлассСтр + " kontour-group " + ИдГруппы + "'>
			|  <td>" + СтрТаб.Дата + "</td>
			|  <td>" + СтрТаб.ИмяСервера + "</td>
			|  <td style='text-align:center; font-weight:600'>" + СтрТаб.МаксИсп + "</td>
			|  <td style='text-align:center'>" + СтрТаб.ВсегоДост + "</td>
			|  <td style='text-align:center;color:" + ЦветПерц + ";font-weight:700'>" + Формат(Перц, "ЧГ=0") + "%</td>
			|  <td style='text-align:center;color:" + ?(Число(СтрТаб.Доступно) < 0, "#e74c3c", "#27ae60") + ";font-weight:600'>" + СтрТаб.Доступно + "</td>
			|</tr>";
			
		КонецЦикла;
		
		ПериодСтр = Формат(ДатаНачала, "ДФ=дд.ММ.гггг") + " — " + Формат(ДатаОкончания, "ДФ=дд.ММ.гггг");
		
		HTML = "<!DOCTYPE html>
		|<html><head><meta charset='utf-8'>
		|<title>Лицензии — динамика за неделю</title>
		|<script src='https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js'></script>
		|<style>
		|  *, *::before, *::after { box-sizing: border-box; }
		|  body  { font-family: Segoe UI, Arial, sans-serif; font-size: 10pt;
		|          background: #f0f4f9; margin: 0; padding: 20px; }
		|  h2    { color: #2c3e50; border-bottom: 3px solid #4472C4;
		|          padding-bottom: 8px; margin-bottom: 20px; }
		|  /* Карточки */
		|  .cards { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 20px; }
		|  .lic-card { background: white; border-radius: 10px; padding: 16px 20px;
		|              box-shadow: 0 2px 8px rgba(0,0,0,0.09); min-width: 280px;
		|              border-top: 4px solid #4472C4; flex: 1; }
		|  .lic-name { font-size: 9pt; font-weight: 700; color: #2c3e50; margin-bottom: 12px; }
		|  .lic-row  { display: flex; gap: 10px; margin-bottom: 10px; }
		|  .lic-block { flex: 1; text-align: center; }
		|  .lic-val  { font-size: 18pt; font-weight: 700; line-height: 1.1; }
		|  .lic-val.blue  { color: #4472C4; }
		|  .lic-val.green { color: #27ae60; }
		|  .lic-lbl  { font-size: 8pt; color: #aaa; margin-top: 2px; }
		|  .progress-wrap { background: #eee; border-radius: 6px; height: 8px; overflow: hidden; }
		|  .progress-bar  { height: 8px; border-radius: 6px; transition: width .4s; }
		|  /* График */
		|  .chart-wrap  { background: white; border-radius: 10px; padding: 20px;
		|                 box-shadow: 0 2px 8px rgba(0,0,0,0.09); margin-bottom: 20px; }
		|  .chart-title { font-size: 11pt; font-weight: 700; color: #2c3e50; margin-bottom: 14px; }
		|  /* Таблица */
		|  .tbl-header { display: flex; align-items: center; justify-content: space-between;
		|                margin-bottom: 8px; flex-wrap: wrap; gap: 8px; }
		|  .tbl-title  { font-size: 11pt; font-weight: 700; color: #2c3e50; }
		|  .btn { padding: 6px 14px; border: none; border-radius: 6px;
		|         cursor: pointer; font-size: 9pt; font-weight: 600; }
		|  .btn-blue { background: #4472C4; color: white; }
		|  .btn-blue:hover { background: #2c5aa0; }
		|  .btn-gray { background: #999; color: white; }
		|  .btn-gray:hover { background: #666; }
		|  .tbl-wrap { background: white; border-radius: 10px; overflow: hidden;
		|              box-shadow: 0 2px 8px rgba(0,0,0,0.09); }
		|  table { border-collapse: collapse; width: 100%; }
		|  th { background: #4472C4; color: white; padding: 9px 8px;
		|       text-align: left; font-size: 9pt; font-weight: 600; }
		|  td { padding: 6px 8px; border-bottom: 1px solid #e8ecf0; }

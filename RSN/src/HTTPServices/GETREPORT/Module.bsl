// Формирует HTML-страницу со списком программных продуктов
// ИСПРАВЛЕНИЕ: ссылка кодируется через JS encodeURIComponent на стороне клиента,
// чтобы спецсимволы XML-ссылки (#, :, пробелы) не ломали URL
Функция СформироватьHTMLСписок(СписокДанных)
	
	СтрокиТаблицы = "";
	Для Каждого Эл Из СписокДанных Цикл
		// Ссылку экранируем для безопасной вставки в HTML-атрибут data-id
		БезопасныйИд = СтрЗаменить(СтрЗаменить(Эл.Ссылка, """", "&quot;"), "'", "&#39;");
		СтрокиТаблицы = СтрокиТаблицы + "
		|<tr class='data-row' data-id='" + БезопасныйИд + "' style='cursor:pointer'>
		|  <td>" + Эл.Код + "</td>
		|  <td style='color:#4472C4;font-weight:600'>" + Эл.Наименование + "</td>
		|</tr>";
	КонецЦикла;
	
	Тело = "
	|<h2> Программные продукты</h2>
	|<div class='tbl-wrap'>
	|<table>
	|<thead><tr>
	|  <th style='width:130px'>Код</th>
	|  <th>Наименование</th>
	|</tr></thead>
	|<tbody>" + СтрокиТаблицы + "</tbody>
	|</table></div>
	|<script>
	|// Переход в карточку через encodeURIComponent — корректно обрабатывает
	|// XML-строки ссылок 1С со спецсимволами (#, :, пробелы)
	|document.querySelectorAll('tr.data-row').forEach(function(row) {
	|  row.addEventListener('click', function() {
	|    var id = row.getAttribute('data-id');
	|    window.location.href = '?' + 'id=' + encodeURIComponent(id);
	|  });
	|});
	|</script>";
	
	Возврат ШаблонHTML("Программные продукты", Тело);
	
КонецФункции

// Формирует HTML-карточку редактирования элемента справочника
Функция СформироватьHTMLКарточку(Данные)
	
	// Поля только для чтения
	ПоляЧтение = Новый Соответствие;
	ПоляЧтение.Вставить("Ссылка", Истина);
	ПоляЧтение.Вставить("Код",    Истина);
	
	СтрокиФормы = "";
	Для Каждого КлючЗнач Из Данные Цикл
		ИмяПоля  = КлючЗнач.Ключ;
		ЗначПоля = КлючЗнач.Значение;
		РО       = ?(ПоляЧтение[ИмяПоля] <> Неопределено, " readonly", "");
		
		// Ссылка передаётся скрытым полем — в форме не показываем
		Если ИмяПоля = "Ссылка" Тогда Продолжить; КонецЕсли;
		
		Если ТипЗнч(ЗначПоля) = Тип("Булево") Тогда
			Чекед = ?(ЗначПоля, " checked", "");
			СтрокиФормы = СтрокиФормы + "
			|<div class='form-row'>
			|  <label>" + ИмяПоля + "</label>
			|  <input type='checkbox' name='" + ИмяПоля + "'" + Чекед + ">
			|</div>";
		Иначе
			БезопасноеЗнач = СтрЗаменить(СтрЗаменить(Строка(ЗначПоля), "&", "&amp;"), """", "&quot;");
			СтрокиФормы = СтрокиФормы + "
			|<div class='form-row'>
			|  <label>" + ИмяПоля + "</label>
			|  <input type='text' name='" + ИмяПоля + "'" + РО + " value=""" + БезопасноеЗнач + """>
			|</div>";
		КонецЕсли;
	КонецЦикла;
	
	Тело = "
	|<div id='toast' class='toast'></div>
	|<h2>✏️ Редактирование: " + Данные["Наименование"] + "</h2>
	|<div class='card'>
	|  <form id='editForm'>
	|    <input type='hidden' name='id' value='" + СтрЗаменить(Данные["Ссылка"], "'", "&#39;") + "'>
	|    " + СтрокиФормы + "
	|    <div style='margin-top:20px'>
	|      <button type='button' class='btn btn-back'
	|        onclick=""history.back()"">← Назад к списку</button>
	|      <button type='button' class='btn btn-save' onclick='saveForm()'> Сохранить</button>
	|    </div>
	|  </form>
	|</div>
	|<script>
	|function saveForm() {
	|  var form = document.getElementById('editForm');
	|  var data = {};
	|  Array.from(form.elements).forEach(function(el) {
	|    if (!el.name) return;
	|    data[el.name] = (el.type === 'checkbox') ? el.checked : el.value;
	|  });
	|  fetch(location.href.split('?')[0], {
	|    method: 'POST',
	|    headers: { 'Content-Type': 'application/json; charset=utf-8' },
	|    body: JSON.stringify(data)
	|  })
	|  .then(function(r) {
	|    return r.text().then(function(txt) {
	|      try { return JSON.parse(txt); }
	|      catch(e) { throw new Error(txt.substring(0, 500)); }
	|    });
	|  })
	|  .then(function(res) { showToast(res.message, !res.ok); })
	|  .catch(function(e) { showToast(e.message, true); });
	|}
	|function showToast(msg, isErr) {
	|  var t = document.getElementById('toast');
	|  t.className = 'toast' + (isErr ? ' err' : '');
	|  t.textContent = msg;
	|  t.style.display = 'block';
	|  setTimeout(function() { t.style.display = 'none'; }, 3000);
	|}
	|</script>";
	
	Возврат ШаблонHTML("Редактирование — " + Данные["Наименование"], Тело);
	
КонецФункции


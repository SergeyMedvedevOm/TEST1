&НаСервере
Процедура ЗаполнитьПрофильИзРСПоПользователю() 
	
	ТЗПолучатели 	= РеквизитФормыВЗначение("Получатели"); 
	МассивИБ		= ТЗПолучатели.ВыгрузитьКолонку("ИБ");
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ПрофилиПользователейСрезПоследних.ИБ КАК ИБ,
	               |	ПрофилиПользователейСрезПоследних.Профиль КАК Профиль
	               |ИЗ
	               |	РегистрСведений.ПрофилиПользователей.СрезПоследних КАК ПрофилиПользователейСрезПоследних
	               |ГДЕ
	               |	ПрофилиПользователейСрезПоследних.Установлено
	               |	И ПрофилиПользователейСрезПоследних.ПользовательИБ.Наименование = &ПользовательИБ
	               |	И ПрофилиПользователейСрезПоследних.ИБ В(&ИБ)";
	Запрос.УстановитьПараметр("ПользовательИБ", Объект.ИмяПользователя);
	Запрос.УстановитьПараметр("ИБ", МассивИБ);
	
	УстановитьПривилегированныйРежим(Истина);
	ТЗПрофили = Запрос.Выполнить().Выгрузить(); 
	УстановитьПривилегированныйРежим(Ложь);
	ТЗПрофили.Индексы.Добавить("ИБ"); 
	Отбор = Новый Структура("ИБ");
	
	Для Каждого Стр Из Получатели Цикл
		
		Отбор.ИБ 	= Стр.ИБ;
		Найдено 	= ТЗПрофили.Скопировать(Отбор, "Профиль");
		
		МассивПрофили = Найдено.ВыгрузитьКолонку("Профиль");
		
		Если ЗначениеЗаполнено(МассивПрофили) Тогда 
			Стр.Профили.ЗагрузитьЗначения(МассивПрофили); 
			Стр.Профили.ЗаполнитьПометки(Истина);
			
			СоответствиеГруп 	= Справочники.ГруппыПрофилей.ПолучитьГруппыПрофилейПоПрофилям(СТр.Иб, МассивПрофили); 
			МассивГрупп 		= СоответствиеГруп.Получить(СТр.Иб);
			Если МассивГрупп = Неопределено = Ложь Тогда 
				Стр.Группы.ЗагрузитьЗначения(МассивГрупп);
				Стр.Группы.ЗаполнитьПометки(Истина);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
		
КонецПроцедуры


&НаСервере
Процедура ВывестиДоступыВТаблицу()
	СпрРеквизит 	= РеквизитФормыВЗначение("Объект");
	ТЗПолучатели 	= РеквизитФормыВЗначение("Получатели");
	ТЗПрофили 		= СпрРеквизит.Доступы.Выгрузить();
	ТЗГруппы 		= СпрРеквизит.ДоступыГруппы.Выгрузить();
	МассивИБ 		= ТЗПрофили.ВыгрузитьКолонку("ИБ");
	МассивИБ 		= ОбщегоНазначенияКлиентСервер.СвернутьМассив(МассивИБ);
	Отбор			= Новый Структура("ИБ");
	Для Каждого База Из МассивИБ Цикл
		Отбор.ИБ 		= База;
		НайденныеСтроки = ТЗПрофили.НайтиСтроки(Отбор);
		НоваяСтрока 	= ТЗПолучатели.Добавить();
		НоваяСтрока.ИБ 	= База;
		Для Каждого Строка Из НайденныеСтроки Цикл
			НоваяСтрока.Профили.Добавить(Строка.Профиль);
		КонецЦикла;
		НайденыеГруппы = ТЗГруппы.НайтиСтроки(Отбор);
		Для Каждого Строка Из НайденыеГруппы Цикл
			НоваяСтрока.Группы.Добавить(Строка.Группа);
		КонецЦикла;		
	КонецЦикла;
	ЗначениеВРеквизитФормы(ТЗПолучатели,"Получатели");
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытииФормыПодбораИБ(Результат, ДополнительныеПараметры) Экспорт 
	
	Если Результат = Неопределено Тогда
		Возврат;	
	КонецЕсли; 	
	
	Для Каждого База Из Результат Цикл  
		НайденнаяСтрока = Получатели.НайтиСтроки(Новый Структура("ИБ", База));
		Если НайденнаяСтрока.Количество() = 0 Тогда
			ЗаполнитьЗначенияСвойств(Получатели.Добавить(), Новый Структура("ИБ", База));			
		КонецЕсли;
	КонецЦикла;
	ДоступыИзменены = Истина;	
КонецПроцедуры 

&НаКлиенте
Процедура ЗаполнитьПрофильПоПользователюЗавершение(Строка, ДополнительныеПараметры) Экспорт
	
	Если НЕ Строка = Неопределено И Не ПустаяСтрока(Строка) Тогда
		//ПользовательШаблон = Строка; 
		ЗаполнитьПрофильПоПользователюНаСервере(Строка)	;
		ДоступыИзменены = Истина;        
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуЗаполненияПрофилейГруппДоступа(ИнформационныеБазы = Неопределено, ТекущиеПрофили = Неопределено, ДополнительныеПараметры = Неопределено)
	
	
	Если ИнформационныеБазы = Неопределено Тогда
		
		ИнформационныеБазы = Новый Массив;  	
		Для Каждого Стр Из Получатели Цикл  	
			
			
			ИнформационныеБазы.Добавить(Стр.ИБ);
			
		КонецЦикла; 
		
	КонецЕсли;
	
	Если ИнформационныеБазы.Количество() = 0 Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru = 'Не выбраны информационные базы для заполнения.'"));
		Возврат;
	КонецЕсли;

	ОбработкаОповещения = Новый ОписаниеОповещения("ПриЗакрытииФормыЗаполненияПрофилейГруппДоступа", ЭтотОбъект, ДополнительныеПараметры);
	
	ОткрытьФорму("Справочник.ПрофилиГруппДоступаИнформационныхБаз.Форма.ФормаПодбораПрофилейГруппДоступа", 
					Новый Структура("ИнформационныеБазы, ТекущиеПрофили", ИнформационныеБазы, ТекущиеПрофили),
						ЭтотОбъект,УникальныйИдентификатор,,,ОбработкаОповещения,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
						
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуЗаполненияГруппДоступа(ИнформационныеБазы = Неопределено, ТекущиеГруппы = Неопределено, ДополнительныеПараметры = Неопределено)
	
	
	Если ИнформационныеБазы = Неопределено Тогда
		
		ИнформационныеБазы = Новый Массив;  	
		Для Каждого Стр Из Получатели Цикл  	
			
			ИнформационныеБазы.Добавить(Стр.ИБ);
			
		КонецЦикла; 
		
	КонецЕсли;
	
	Если ИнформационныеБазы.Количество() = 0 Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru = 'Не выбраны информационные базы для заполнения.'"));
		Возврат;
	КонецЕсли;  
	Если ДополнительныеПараметры = Неопределено Тогда 
		ДополнительныеПараметры  = Новый Структура;
	КонецЕсли;
	ДополнительныеПараметры.Вставить("Режим", "Группы");
	ОбработкаОповещения = Новый ОписаниеОповещения("ПриЗакрытииФормыЗаполненияПрофилейГруппДоступа", ЭтотОбъект, ДополнительныеПараметры);
	
	ОткрытьФорму("Справочник.ГруппыПрофилей.Форма.ФормаПодбораГруппДоступа", 
					Новый Структура("ИнформационныеБазы, ТекущиеГруппы", ИнформационныеБазы, ТекущиеГруппы),
						ЭтотОбъект,УникальныйИдентификатор,,,ОбработкаОповещения,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
						
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытииФормыЗаполненияПрофилейГруппДоступа(Результат, ДополнительныеПараметры) Экспорт 
	
	Если Результат = Неопределено Тогда
		Возврат;	
	КонецЕсли;  
	ДоступыИзменены = Истина;
	ПриЗакрытииФормыЗаполненияПрофилейГруппДоступаНаСервере(Результат, ДополнительныеПараметры);
			
КонецПроцедуры  

&НаСервереБезКонтекста
Функция ПолучитьРежим(ДополнительныеПараметры) 
	Режим = "Профили"; 
	Если ЗначениеЗаполнено(ДополнительныеПараметры) Тогда 
		Если ДополнительныеПараметры.Свойство("Режим") и ЗначениеЗаполнено(ДополнительныеПараметры.Режим) Тогда 
			Режим = ДополнительныеПараметры.Режим;
		КонецЕсли;
	КонецЕсли;    
	Возврат Режим;
КонецФункции

&НаСервереБезКонтекста
Процедура ЗаполнитьСтроку(Стр, Режим, ВыбранныеЗначения)  
	Стр[Режим].ЗагрузитьЗначения(ВыбранныеЗначения);
	Стр[Режим].ЗаполнитьПометки(Истина); 
	
	МассивПрофилейГрупп  	= ПолучитьМассивПрофилейГрупп(Стр.ИБ, Стр.Группы.ВыгрузитьЗначения());
	МассивПрофилей 			= Стр.Профили.ВыгрузитьЗначения();
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(МассивПрофилейГрупп, МассивПрофилей, Истина); 
	
	Стр.Профили.ЗагрузитьЗначения(МассивПрофилейГрупп);
КонецПроцедуры


&НаСервере
Процедура ПриЗакрытииФормыЗаполненияПрофилейГруппДоступаНаСервере(Результат, ДополнительныеПараметры)
	
	Если Не Результат.Получить(Перечисления.КонфигурацииИнформационныхБаз.ПустаяСсылка()) = Неопределено Тогда
		//заполняем по всем    
		Режим = ПолучитьРежим(ДополнительныеПараметры);
		
		ВыбранныеЗначения = Результат.Получить(Перечисления.КонфигурацииИнформационныхБаз.ПустаяСсылка());
		Для Каждого Стр Из Получатели Цикл
			ЗаполнитьСтроку(Стр, Режим, ВыбранныеЗначения);
			//Стр[Режим].Очистить();
			//Для каждого Значение Из ВыбранныеЗначения Цикл
			//	Стр[Режим].Добавить(Значение,,Истина);	
			//КонецЦикла;	
			//Стр[Режим].ЗагрузитьЗначения(ВыбранныеЗначения);
			//Стр[Режим].ЗаполнитьПометки(Истина); 
			//

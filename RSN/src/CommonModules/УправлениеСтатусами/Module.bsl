	"                  border-radius:4px;'>" +
	"          Согласовано" +
	"        </a>" +
	"      </td>" +
	"      <td style='width:10px;font-size:0;line-height:0;'>&nbsp;</td>" +
	"      <td bgcolor='#c62828' style='border-radius:4px;'>" +
	"        <a href='" + СсылкаНеСогласовано + "' " +
	"           style='display:inline-block;" +
	"                  padding:10px 18px;" +
	"                  font-family:Arial,sans-serif;" +

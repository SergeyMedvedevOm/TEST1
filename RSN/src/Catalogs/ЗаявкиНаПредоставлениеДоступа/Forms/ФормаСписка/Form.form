  <showTitle>true</showTitle>
  <showCloseButton>true</showCloseButton>
  <attributes>
    <name>Список</name>
    <id>1</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.СрочностьПорядок</segments>
    </notDefaultUseAlwaysAttributes>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ЗаявкиНаПредоставлениеДоступа.Ссылка,
	ЗаявкиНаПредоставлениеДоступа.ПометкаУдаления,
	ЗаявкиНаПредоставлениеДоступа.Код,
	ЗаявкиНаПредоставлениеДоступа.Наименование,
	ЗаявкиНаПредоставлениеДоступа.Автор,
	ЗаявкиНаПредоставлениеДоступа.Описание,
	ЗаявкиНаПредоставлениеДоступа.Срочность,
	ЗаявкиНаПредоставлениеДоступа.СоздатьПользователя,
	ЗаявкиНаПредоставлениеДоступа.ДатаЗаявки,
	ЗаявкиНаПредоставлениеДоступа.ИмяПользователя,
	ЗаявкиНаПредоставлениеДоступа.Предопределенный,
	ЗаявкиНаПредоставлениеДоступа.ИмяПредопределенныхДанных,
	ВЫБОР
		КОГДА СтатусыЗаявокСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявок.Согласовано)
			ТОГДА 1
		КОГДА СтатусыЗаявокСрезПоследних.Статус В (ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявок.Отозвано),
			ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявок.ОтказаноВСогласовании))
			ТОГДА 2
		КОГДА СтатусыЗаявокСрезПоследних.Статус В (ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявок.Создано))
			ТОГДА 0
		ИНАЧЕ 1
	КОНЕЦ КАК НомерКартинки,
	СтатусыЗаявокСрезПоследних.Статус,
	СтатусыЗаявокСрезПоследних.Автор КАК АвторСтатуса,
	ЗаявкиНаПредоставлениеДоступа.Срочность.Порядок
ИЗ
	РегистрСведений.СтатусыЗаявок.СрезПоследних КАК СтатусыЗаявокСрезПоследних
		ПРАВОЕ СОЕДИНЕНИЕ Справочник.ЗаявкиНаПредоставлениеДоступа КАК ЗаявкиНаПредоставлениеДоступа
		ПО СтатусыЗаявокСрезПоследних.Заявка = ЗаявкиНаПредоставлениеДоступа.Ссылка</queryText>
      <mainTable>Catalog.ЗаявкиНаПредоставлениеДоступа</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>

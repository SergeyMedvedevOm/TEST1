		МассивЗаявки = Заявки;
	Иначе 
		МассивЗаявки = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Заявки);
	КонецЕсли;           
	
	ТД = ТекущаяДата();
	
	Для Каждого Эл Из МассивЗаявки Цикл 
		Мз = СоздатьМенеджерЗаписи();

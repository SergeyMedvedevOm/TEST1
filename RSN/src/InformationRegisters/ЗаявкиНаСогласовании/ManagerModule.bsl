			Мз.Записать(Истина); 
		Исключение
			МассивОшибок.Добавить(ОписаниеОшибки());
		КонецПопытки;
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(МассивОшибок) Тогда 
		Ответ.ЕстьОшибка = Истина;
		Ответ.ОписаниеОшибки = СтрСоединить(МассивОшибок,Символы.ПС);
	КонецЕсли;
	Возврат Ответ;

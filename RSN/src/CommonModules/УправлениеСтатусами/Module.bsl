	HTML =
	"<div style='font-family:Arial,sans-serif;font-size:14px;'>" +
	"  <p style='margin:0 0 12px 0;'><b>Пожалуйста, выберите действие:</b></p>" +
	"  <table role='presentation' cellpadding='0' cellspacing='0' border='0'>" +

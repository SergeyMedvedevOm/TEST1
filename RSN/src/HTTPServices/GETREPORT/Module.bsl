// БЛОК 7: Вспомогательные функции формирования HTTP-ответов
// ══════════════════════════════════════════════════════════════

Функция СформироватьОтвет200(HTML)
	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.Заголовки.Вставить("Content-Type", "text/html; charset=utf-8");
	Ответ.УстановитьТелоИзСтроки(HTML);
	Возврат Ответ;
КонецФункции

Функция СформироватьОтветJSON(Знач ДанныеСтруктура)
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, ДанныеСтруктура);
	JSONСтрока = ЗаписьJSON.Закрыть();
	
	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.УстановитьТелоИзСтроки(JSONСтрока);
	Возврат Ответ;
КонецФункции

Функция СформироватьОтветОшибка(ТекстОшибки)
	Ответ = Новый HTTPСервисОтвет(500);
	Ответ.Заголовки.Вставить("Content-Type", "text/plain; charset=utf-8");
	Ответ.УстановитьТелоИзСтроки("Ошибка: " + ТекстОшибки);
	Возврат Ответ;
КонецФункции


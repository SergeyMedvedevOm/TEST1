#Область Интерфейс

#Область МаршрутыЗаявкаНаПраваДоступа
Функция ПолучитьСледующийШаг(ТекущийШаг = Неопределено) Экспорт
	Если ЗначениеЗаполнено(ТекущийШаг) = Ложь Тогда 
		Возврат ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.Создано"));
	КонецЕсли;
	
	Ответ = Новый Массив;
	
	Если ТекущийШаг = ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.Создано") Тогда 
		Ответ.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.НаСогласовании"));
		Ответ.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.Отозвано"));
	ИначеЕсли ТекущийШаг = ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.НаСогласовании") Тогда
		Ответ.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.Создано"));
		Ответ.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.Согласовано"));
		Ответ.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.ОтказаноВСогласовании"));
		Ответ.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.Отозвано"));
	ИначеЕсли ТекущийШаг = ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.Согласовано") Тогда 
		Ответ.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.ВРаботе"));
		Ответ.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.Отозвано"));
	ИначеЕсли ТекущийШаг = ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.ВРаботе") Тогда 
		Ответ.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.Завершено"));
		Ответ.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.ОшибкаВыполнения"));
		Ответ.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.Отозвано"));
	КонецЕсли;
	
	Возврат Ответ;
КонецФункции

Функция ВыполнитьПостобработчик(Заявка, ТекущийШаг) Экспорт    
	Если ТекущийШаг = ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.НаСогласовании") Тогда  
		Результат = ОтправитьНаСогласование(Заявка); 
	ИначеЕсли ТекущийШаг = ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.Создано") Тогда  
		Результат = ОтменитьСогласование(Заявка);                                                            
	ИначеЕсли ТекущийШаг = ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.Согласовано") Тогда 
		//Результат = ОтработатьСогласовано(Заявка);
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

#КонецОбласти

#Область Служебные 
Функция ОтработатьСогласовано(Заявка) Экспорт 
	Результат = Справочники.ЗаявкиНаПредоставлениеДоступа.ВыдатьПраваПоЗаявке(Заявка); 
	Если Результат.ЕстьОшибка Тогда 
		РегистрыСведений.СтатусыЗаявок.УстановитьСтатус(Заявка, ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.ОшибкаВыполнения"));
		Шаблон = "Заявка %1, описание: %2";
		
		СтруктураСобытий = Новый Структура("ИмяСобытия, ПредставлениеУровня, Комментарий,ДатаСобытия");
		СтруктураСобытий.ИмяСобытия 		 = "ЗаявкаНПД.ВыдатьПрава";
		СтруктураСобытий.ПредставлениеУровня = "Ошибка";	//"Информация", "Ошибка", "Предупреждение", "Примечание".
		СтруктураСобытий.Комментарий 		 = СтрШаблон(Шаблон, Строка(Заявка), Результат.ОписаниеОшибки);
		
		События = Новый СписокЗначений;
		События.Добавить(СтруктураСобытий);
		
		ЖурналРегистрации.ЗаписатьСобытияВЖурналРегистрации(События);
	Иначе 
		РегистрыСведений.СтатусыЗаявок.УстановитьСтатус(Заявка, ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.Завершено"));
	КонецЕсли;
	
	Возврат Результат
КонецФункции

Функция ОтменитьСогласование(Заявка) Экспорт   
	Возврат РегистрыСведений.ЗаявкиНаСогласовании.ОтменитьСогласование(Заявка);
КонецФункции

Функция ОтправитьНаСогласование(Заявка) Экспорт   
	Ответ = Новый Структура("Результат, ОписаниеОшибки, ЕстьОшибка", Ложь, "", Ложь);  
	
	МассивСогласющих = РегистрыСведений.УчастникиПочтовойРассылки.ПолучитьСогласующих();
	
	СтруктураПисьма = Справочники.ЗаявкиНаПредоставлениеДоступа.ПолучитьСтруктуруПисьма();
	СтруктураПисьма.МассивАдресов 	= МассивСогласющих;
	СтруктураПисьма.ШаблонТема 		= "Требуется согласование доступа, заявка {Код} от {ДатаЗаявки}";
	//СтруктураПисьма.ШаблонТело 		= "Заявка [Код] от [ДатаЗаявки]";    
	Гуид = Новый УникальныйИдентификатор;
	СтруктураПисьма.ШаблонТело 		= ПолучитьШаблонТелоСогласовано(Гуид);//"Заявка [Код] от [ДатаЗаявки]";
	//СтруктураПисьма.ДопПараметры = Новый Структура("Статус", НовыйСтатус);
	
	Результат = Справочники.ЗаявкиНаПредоставлениеДоступа.ОтправитьПисьмо(Заявка, СтруктураПисьма);
	
	//Результат = Взаимодействия.СоздатьПисьмо(Сообщение, УЗ);
	
	Если Результат.ЕстьОшибка Тогда 
		//ОбщегоНазначения.СообщитьПользователю("Письмо не создано/не отправлено: " + Результат.ОписаниеОшибки);
		//
		//Ответ.ЕстьОшибка 	 = Истина;
		//Ответ.ОписаниеОшибки = Результат.ОписаниеОшибки;
		Возврат Ответ;
	КонецЕсли; 
	
	//Установим признак согласования 
	Структура = Новый Структура("Заявка,Письмо");//, Заявка,Результат.СсылкаНаПисьмо);
	ЗаполнитьЗначенияСвойств(Структура, Результат.Результат);
	Структура.Вставить("Гуид", Гуид);
	
	Возврат РегистрыСведений.ЗаявкиНаСогласовании.ОтправитьНаСогласование(Структура);
КонецФункции  


	//
	//Запрос.УстановитьПараметр("СтатусВРаботе", ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.ВРаботе"));
	//
	//Результат = Запрос.Выполнить().Выгрузить();
	//Если Результат.Количество() = 0 = Ложь Тогда 
	//КонецЕсли;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	СтатусыЗаявокСрезПоследних.Заявка КАК Заявка
	               |ИЗ
	               |	РегистрСведений.СтатусыЗаявок.СрезПоследних КАК СтатусыЗаявокСрезПоследних
	               |ГДЕ
	               |	СтатусыЗаявокСрезПоследних.Статус = &СтатусСогласовано";
	Запрос.УстановитьПараметр("СтатусСогласовано", ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.Согласовано"));
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда 
		Возврат;
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл  
		УправлениеСтатусами.ОтработатьСогласовано(Выборка.Заявка);
	КонецЦикла;
	
	
КонецПроцедуры

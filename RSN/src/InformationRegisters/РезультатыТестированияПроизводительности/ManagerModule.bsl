Функция ЗаписатьРезультатТестирования(Структура) Экспорт    
	Ответ 	= Новый Структура("Результат,ЕстьОшибка,ОписаниеОшибки", Истина,Ложь,"");
	
	МЗ 		= СоздатьМенеджерЗаписи();
	ЗаполнитьЗначенияСвойств(МЗ, Структура);
	
	Попытка
		МЗ.Записать(Истина);
	Исключение
		Ответ.Результат 	 = Ложь;
		Ответ.ЕстьОшибка 	 = Истина;
		Ответ.ОписаниеОшибки = ОписаниеОшибки();
	КонецПопытки;
	
	Возврат Ответ;
КонецФункции

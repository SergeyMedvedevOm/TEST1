&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ИзменениеНастроекАвторизации" Тогда		
		НастройкиАвторизации = ИнтеграцияКлиент.ПолучитьНастройкиАвторизации();	
	ИначеЕсли ИмяСобытия = "Запись_ЗаявкиНаПредоставлениеДоступа" Тогда
		Если Источник = Объект.Ссылка Тогда
			ОбновитьСтатус();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Если Параметры.Свойство("Ключ") и Не ЗначениеЗаполнено(Параметры.Ключ) Тогда
		Объект.ДатаЗаявки 	= НачалоДня(ОбщегоНазначения.ТекущаяДатаПользователя());
		Объект.Автор 		= Пользователи.АвторизованныйПользователь();
		Объект.Срочность 	= ПредопределенноеЗначение("Перечисление.ПриоритетыЗаявок.Нормальный");
		ЭтоНовый 			= Истина;	
		Статус 				= ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.Создано");
		ЗаполнитьНаблюдателейПоУмолчанию(Объект.Наблюдатели);
	Иначе
		ВывестиДоступыВТаблицу();
		ОбновитьСтатус();
	КонецЕсли  
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНаблюдателейПоУмолчанию(ТЗ)  
	ТЗ.Очистить();
	ТзПоУмолчанию =  РегистрыСведений.УчастникиПочтовойРассылки.ПолучитьЗначенияПоУмолчанию(ПредопределенноеЗначение("Перечисление.ВидыРассылок.ЗаявкаНаВыдачуПрав"));
	Если ЗначениеЗаполнено(ТзПоУмолчанию) = Ложь Тогда 
		Возврат;
	КонецЕсли;
	Для Каждого Эл Из ТзПоУмолчанию Цикл 
		ЗаполнитьЗначенияСвойств(ТЗ.Добавить(), Эл);
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	Если ЭтоНовый Тогда
		Если РегистрыСведений.СтатусыЗаявок.УстановитьСтатус(ТекущийОбъект.Ссылка, ПредопределенноеЗначение("Перечисление.СтатусыЗаявок.Создано")).Результат = Ложь Тогда
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	Если Объект.Наименование = "" Тогда
		Объект.Наименование = (Объект.ИмяПользователя);
	КонецЕсли;
	
	Если ДоступыИзменены Тогда
		ЗаполнитьТЧДоступы();
		ДоступыИзменены = Ложь;
	КонецЕсли;
КонецПроцедуры
#КонецОбласти


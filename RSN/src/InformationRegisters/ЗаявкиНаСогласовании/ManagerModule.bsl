Функция ПолучитьЗаявкиНаСогласовании() Экспорт  
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЗаявкиНаСогласованииСрезПоследних.Заявка КАК Заявка,
	               |	ЗаявкиНаСогласованииСрезПоследних.Состояние КАК Состояние,
	               |	ЗаявкиНаСогласованииСрезПоследних.Письмо КАК Письмо,
	               |	ЗаявкиНаСогласованииСрезПоследних.Гуид КАК Гуид
	               |ИЗ
	               |	РегистрСведений.ЗаявкиНаСогласовании.СрезПоследних КАК ЗаявкиНаСогласованииСрезПоследних
	               |ГДЕ
	               |	ЗаявкиНаСогласованииСрезПоследних.Состояние = 0";
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

Функция ОтправитьНаСогласование(Заявки) Экспорт
	Ответ 		 = Новый Структура("Результат, ОписаниеОшибки, ЕстьОшибка", Ложь, "", Ложь);	
	МассивОшибок = Новый Массив;
	
	Если ТипЗнч(Заявки) = Тип("Массив") Тогда 
		МассивЗаявки = Заявки;
	Иначе 
		МассивЗаявки = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Заявки);
	КонецЕсли;           
	
	ТД = ТекущаяДата();
	
	Для Каждого Эл Из МассивЗаявки Цикл 
		Мз = СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(Мз, Эл);
		Мз.Период = ТД; 
		
		//Мз.Заявка = Эл.Заявка;
		//Мз.Письмо = Эл.Письмо;
		МЗ.Состояние = 0;//отправлено на согласование  
		Попытка 
			Мз.Записать(Истина); 
		Исключение
			МассивОшибок.Добавить(ОписаниеОшибки());
		КонецПопытки;
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(МассивОшибок) Тогда 
		Ответ.ЕстьОшибка = Истина;
		Ответ.ОписаниеОшибки = СтрСоединить(МассивОшибок,Символы.ПС);
	КонецЕсли;
	Возврат Ответ;
КонецФункции

Функция ОтменитьСогласование(Заявки) Экспорт  
	Ответ 		 = Новый Структура("Результат, ОписаниеОшибки, ЕстьОшибка", Ложь, "", Ложь);	
	МассивОшибок = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЗаявкиНаСогласованииСрезПоследних.Заявка КАК Заявка
	               |ИЗ
	               |	РегистрСведений.ЗаявкиНаСогласовании.СрезПоследних(, Заявка в (&Заявка)) КАК ЗаявкиНаСогласованииСрезПоследних";
	Запрос.УстановитьПараметр("Заявка", Заявки);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Тд = ТекущаяДата();
	Пока Выборка.Следующий() Цикл 
		МЗ = СоздатьМенеджерЗаписи();
		МЗ.Период 		= Тд;
		МЗ.Заявка 		= Выборка.Заявка;
		МЗ.Состояние 	= 2;//отменено
		Попытка
			Мз.Записать(Истина);
		Исключение
			МассивОшибок.Добавить(ОписаниеОшибки());
		КонецПопытки;
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(МассивОшибок) Тогда 
		Ответ.ЕстьОшибка = Истина;
		Ответ.ОписаниеОшибки = СтрСоединить(МассивОшибок,Символы.ПС);
	КонецЕсли;
	Возврат Ответ;
	
КонецФункции

Функция ЗавершитьСогласование(Заявки) Экспорт

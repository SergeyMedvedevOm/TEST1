// ═══════════════════════════════════════════════════════════════
// HTTP-сервис: POSTMESSAGE
// Назначение: CRUD-интерфейс справочника ПрограммныеПродукты
// Методы: GET  — список + карточка редактирования
//         POST — сохранение изменений
// ═══════════════════════════════════════════════════════════════

// ──────────────────────────────────────────────────────────────
// БЛОК 1: Точка входа GET — маршрутизация
// ──────────────────────────────────────────────────────────────
Функция POSTMESSAGEGet(Запрос) Экспорт
	
	Попытка
		
		// ПараметрыЗапроса — это query string (?id=...), НЕ ПараметрыURL
		// ПараметрыURL — только для параметров шаблона вида /POSTMESSAGE/{id}/
		ИдСтр = Запрос.ПараметрыЗапроса.Получить("id");
		
		Если ИдСтр = Неопределено ИЛИ ПустаяСтрока(ИдСтр) Тогда
			СписокДанных = ПолучитьСписокПродуктов();
			HTML = СформироватьHTMLСписок(СписокДанных);
		Иначе
			ДанныеЭлемента = ПолучитьДанныеЭлемента(ИдСтр);
			HTML = СформироватьHTMLКарточку(ДанныеЭлемента);
		КонецЕсли;
		
	Исключение
		Возврат СформироватьОтветОшибка(ОписаниеОшибки());
	КонецПопытки;
	
	Возврат СформироватьОтвет200(HTML);
	
КонецФункции// ──────────────────────────────────────────────────────────────
// БЛОК 2: Точка входа POST — сохранение изменений из карточки
// Принимает JSON с реквизитами, обновляет элемент справочника
// ──────────────────────────────────────────────────────────────
Функция POSTMESSAGEPost(Запрос) Экспорт
	
	Попытка
		
		// Читаем тело запроса (JSON) встроенными средствами платформы
		ТелоJSON = Запрос.ПолучитьТелоКакСтроку();
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ТелоJSON);
		ДанныеJSON = ПрочитатьJSON(ЧтениеJSON);
		
		// Сохраняем и получаем результат
		РезультатСохранения = СохранитьЭлемент(ДанныеJSON);
		
		Возврат СформироватьОтветJSON(РезультатСохранения);
		
	Исключение
		Возврат СформироватьОтветОшибка(ОписаниеОшибки());
	КонецПопытки;
	
КонецФункции


// Возвращает массив структур: все элементы справочника ПрограммныеПродукты
Функция ПолучитьСписокПродуктов()
	
	Массив = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ПП.Ссылка                   КАК Ссылка,
	|	ПП.Код                      КАК Код,
	|	ПП.Наименование             КАК Наименование,
	|	ПП.Продукт                  КАК Продукт,
	|	ПП.ДляКого                  КАК ДляКого,
	|	ПП.УКогоКуплен              КАК УКогоКуплен,
	|	ПП.Логин                    КАК Логин,
	|	ПП.Пароль                   КАК Пароль,
	|	ПП.СрокДействия             КАК СрокДействия,
	|	ПП.Почта                    КАК Почта,
	|	ПП.Телефон                  КАК Телефон,
	|	ПП.РасположениеApplication  КАК РасположениеApplication,
	|	ПП.ОтветственныйБухгалтер   КАК ОтветственныйБухгалтер,
	|	ПП.ОрганизацияВРегКарточке  КАК ОрганизацияВРегКарточке,
	|	ПП.ОрганизацияНаКогоКуплен  КАК ОрганизацияНаКогоКуплен,
	|	ПП.ВидПрограммногоПродукта  КАК ВидПрограммногоПродукта,
	|	ПП.ОрганизацияДляКогоКуплен КАК ОрганизацияДляКогоКуплен
	|ИЗ
	|	Справочник.ПрограммныеПродукты КАК ПП
	|ГДЕ
	|	ПП.ПометкаУдаления = ЛОЖЬ
	|УПОРЯДОЧИТЬ ПО
	|	ПП.Наименование";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		// Структура строго соответствует полям запроса — без лишних ключей
		Стр = Новый Структура(
		"Ссылка, Код, Наименование, Продукт, ДляКого, УКогоКуплен,
		|Логин, Пароль, СрокДействия, Почта, Телефон,
		|РасположениеApplication, ОтветственныйБухгалтер,
		|ОрганизацияВРегКарточке, ОрганизацияНаКогоКуплен,
		|ВидПрограммногоПродукта, ОрганизацияДляКогоКуплен");
		
		Стр.Ссылка                   = XMLСтрока(Выборка.Ссылка);
		Стр.Код                      = Строка(Выборка.Код);
		Стр.Наименование             = Строка(Выборка.Наименование);
		Стр.Продукт                  = Строка(Выборка.Продукт);
		Стр.ДляКого                  = Строка(Выборка.ДляКого);
		Стр.УКогоКуплен              = Строка(Выборка.УКогоКуплен);
		Стр.Логин                    = Строка(Выборка.Логин);
		Стр.Пароль                   = Строка(Выборка.Пароль);
		Стр.СрокДействия             = Формат(Выборка.СрокДействия, "ДФ=дд.ММ.гггг");
		Стр.Почта                    = Строка(Выборка.Почта);
		Стр.Телефон                  = Строка(Выборка.Телефон);
		Стр.РасположениеApplication  = Строка(Выборка.РасположениеApplication);
		Стр.ОтветственныйБухгалтер   = Строка(Выборка.ОтветственныйБухгалтер);
		Стр.ОрганизацияВРегКарточке  = Строка(Выборка.ОрганизацияВРегКарточке);
		Стр.ОрганизацияНаКогоКуплен  = Строка(Выборка.ОрганизацияНаКогоКуплен);
		Стр.ВидПрограммногоПродукта  = Строка(Выборка.ВидПрограммногоПродукта);
		Стр.ОрганизацияДляКогоКуплен = Строка(Выборка.ОрганизацияДляКогоКуплен);
		
		Массив.Добавить(Стр);
	КонецЦикла;
	
	Возврат Массив;
	
КонецФункции

// Возвращает структуру со всеми реквизитами одного элемента по XML-строке ссылки
Функция ПолучитьДанныеЭлемента(ИдСтр)
	
	Ссылка = XMLЗначение(Тип("СправочникСсылка.ПрограммныеПродукты"), ИдСтр);
	Объект = Ссылка.ПолучитьОбъект();
	
	Если Объект = Неопределено Тогда
		ВызватьИсключение "Элемент не найден: " + ИдСтр;
	КонецЕсли;
	
	// Стандартные поля
	Данные = Новый Структура;
	Данные.Вставить("Ссылка",       ИдСтр);
	Данные.Вставить("Наименование", Строка(Объект.Наименование));
	Данные.Вставить("Код",          Строка(Объект.Код));
	
	// Перебираем все реквизиты метаданных — универсально
	Для Каждого Рекв Из Объект.Метаданные().Реквизиты Цикл
		ЗначРекв = Объект[Рекв.Имя];
		Если ТипЗнч(ЗначРекв) = Тип("Булево")
			ИЛИ ТипЗнч(ЗначРекв) = Тип("Число")
			ИЛИ ТипЗнч(ЗначРекв) = Тип("Строка") Тогда
			Данные.Вставить(Рекв.Имя, ЗначРекв);
		ИначеЕсли ТипЗнч(ЗначРекв) = Тип("Дата") Тогда
			Данные.Вставить(Рекв.Имя, Формат(ЗначРекв, "ДФ=дд.ММ.гггг"));
		Иначе
			Данные.Вставить(Рекв.Имя, Строка(ЗначРекв));
		КонецЕсли;
	КонецЦикла;
	
	Возврат Данные;
	
КонецФункции

// ══════════════════════════════════════════════════════════════
// БЛОК 4: Сохранение изменений в БД
// ══════════════════════════════════════════════════════════════

Функция СохранитьЭлемент(ДанныеJSON)
	
	ИдСтр  = ДанныеJSON["id"];
	Ссылка = XMLЗначение(Тип("СправочникСсылка.ПрограммныеПродукты"), ИдСтр);
	Объект = Ссылка.ПолучитьОбъект();
	
	Если Объект = Неопределено Тогда
		ВызватьИсключение "Элемент не найден: " + ИдСтр;
	КонецЕсли;
	
	Мета = Объект.Метаданные();
	
	Для Каждого КлючЗнач Из ДанныеJSON Цикл
		ИмяРекв = КлючЗнач.Ключ;
		Если ИмяРекв = "id" Тогда Продолжить; КонецЕсли;
		
		Если ИмяРекв = "Наименование" Тогда
			Объект.Наименование = КлючЗнач.Значение;
			Продолжить;
		КонецЕсли;
		
		МетаРекв = Мета.Реквизиты.Найти(ИмяРекв);
		Если МетаРекв = Неопределено Тогда Продолжить; КонецЕсли;
		
		ТипыРекв = МетаРекв.Тип.Типы();
		Если ТипыРекв.Количество() > 0 Тогда
			ЦелевойТип = ТипыРекв[0];
			Попытка
				Если ЦелевойТип = Тип("Булево") Тогда
					Объект[ИмяРекв] = КлючЗнач.Значение = "true" ИЛИ КлючЗнач.Значение = Истина;
				ИначеЕсли ЦелевойТип = Тип("Число") Тогда
					Объект[ИмяРекв] = Число(КлючЗнач.Значение);
				ИначеЕсли ЦелевойТип = Тип("Дата") Тогда
					Объект[ИмяРекв] = ЗначениеИзСтрокиВнутр(КлючЗнач.Значение);
				Иначе
					Объект[ИмяРекв] = КлючЗнач.Значение;
				КонецЕсли;
			Исключение
				// Пропускаем поле, если не удалось привести тип
			КонецПопытки;
		КонецЕсли;
	КонецЦикла;
	УстановитьПривилегированныйРежим(Истина);
	Объект.Записать();
	УстановитьПривилегированныйРежим(Ложь);
	Рез = Новый Структура("ok, message, id");
	Рез.ok      = Истина;
	Рез.message = "Сохранено успешно";
	Рез.id      = ИдСтр;
	Возврат Рез;
	
КонецФункции

